{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullforge.example/schemas/preview-session.schema.json",
  "title": "NullForge Preview Session",
  "type": "object",
  "required": [
    "document_type",
    "schema_version",
    "app_version",
    "exported_at",
    "mode",
    "sample_rate_hz",
    "state",
    "automation_events",
    "automation_tracks",
    "limitations"
  ],
  "properties": {
    "document_type": {"const": "nullforge_preview_session"},
    "schema_version": {"const": "0.1.0"},
    "app_version": {"type": "string", "minLength": 1},
    "exported_at": {"type": "string", "format": "date-time"},
    "mode": {"const": "preview_not_truth_engine"},
    "sample_rate_hz": {"type": "integer", "minimum": 8000, "maximum": 384000},
    "state": {
      "type": "object",
      "required": ["sources", "noise", "intervention", "visualization"],
      "properties": {
        "sources": {
          "type": "object",
          "required": ["A", "B"],
          "properties": {
            "A": {"$ref": "#/$defs/source"},
            "B": {"$ref": "#/$defs/source"}
          },
          "additionalProperties": false
        },
        "noise": {
          "type": "object",
          "required": ["gain", "cutoff_hz"],
          "properties": {
            "gain": {"type": "number", "minimum": 0, "maximum": 2},
            "cutoff_hz": {"type": "number", "minimum": 20, "maximum": 96000}
          },
          "additionalProperties": false
        },
        "intervention": {
          "type": "object",
          "required": ["enabled", "condition", "threshold_deg", "audio_multiplier", "active"],
          "properties": {
            "enabled": {"type": "boolean"},
            "condition": {"enum": ["opposition", "convergence"]},
            "threshold_deg": {"type": "number", "minimum": 0, "maximum": 180},
            "audio_multiplier": {"type": "number", "minimum": 0, "maximum": 8},
            "active": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "visualization": {
          "type": "object",
          "required": ["intervention_exaggeration", "frozen"],
          "properties": {
            "intervention_exaggeration": {"type": "number", "minimum": 1, "maximum": 1000},
            "frozen": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "automation_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["t_ms", "target", "value"],
        "properties": {
          "t_ms": {"type": "number", "minimum": 0},
          "target": {"type": "string", "minLength": 1},
          "value": {
            "oneOf": [
              {"type": "number"},
              {"type": "string"},
              {"type": "boolean"},
              {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 4}
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "automation_tracks": {
      "type": "array",
      "items": {"$ref": "https://nullforge.example/schemas/automation.schema.json"}
    },
    "snapshot": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": [
            "schema_version",
            "app_version",
            "captured_at",
            "truth_state",
            "interaction_state",
            "intervention_state",
            "visualization_state",
            "evidence_class"
          ],
          "properties": {
            "schema_version": {"const": "0.1.0"},
            "app_version": {"type": "string"},
            "captured_at": {"type": "string", "format": "date-time"},
            "audio_context": {"type": ["object", "null"]},
            "truth_state": {"type": "object"},
            "interaction_state": {"type": "object"},
            "intervention_state": {"type": "object"},
            "visualization_state": {"type": "object"},
            "evidence_class": {"const": "PREVIEW_SNAPSHOT_NOT_DETERMINISTIC_EVIDENCE"}
          },
          "additionalProperties": false
        }
      ]
    },
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["enabled", "frequency_hz", "gain", "phase_deg", "route", "harmonics"],
      "properties": {
        "enabled": {"type": "boolean"},
        "frequency_hz": {"type": "number", "exclusiveMinimum": 0, "maximum": 96000},
        "gain": {"type": "number", "minimum": 0, "maximum": 2},
        "phase_deg": {"type": "number", "minimum": -360, "maximum": 360},
        "route": {"enum": ["L", "C", "R"]},
        "harmonics": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {"type": "number", "minimum": 0, "maximum": 2}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
