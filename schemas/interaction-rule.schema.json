{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullforge.example/schemas/interaction-rule.schema.json",
  "title": "Interaction Rule",
  "type": "object",
  "required": ["id", "sensor", "condition", "responses"],
  "properties": {
    "id": {"type": "string"},
    "sensor": {
      "type": "object",
      "required": ["type", "metric"],
      "properties": {
        "type": {"enum": ["metric", "geometry", "event"]},
        "metric": {"type": "string"}
      },
      "additionalProperties": true
    },
    "condition": {
      "type": "object",
      "required": ["operator"],
      "properties": {
        "operator": {"enum": ["less_than", "greater_than", "between", "crossing", "minimum", "maximum"]},
        "value": {"type": "number"},
        "min": {"type": "number"},
        "max": {"type": "number"},
        "hysteresis": {"type": "number", "minimum": 0},
        "hold_samples": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["classification", "type"],
        "properties": {
          "classification": {"enum": ["OBSERVATION_MODIFIER", "EXPERIMENTAL_INTERVENTION", "SNAPSHOT"]},
          "type": {"type": "string"},
          "target": {"type": "string"},
          "value": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
