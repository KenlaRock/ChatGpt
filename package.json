{
  "name": "northstar-release-deck",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit:prod": "npm audit --omit=dev",
    "netlify:build:primary": "curl -X POST -H 'Content-Type: application/json' -d '{}' https://api.netlify.com/build_hooks/68c5145c373799bfa07a2d69",
    "netlify:build:secondary": "curl -X POST -H 'Content-Type: application/json' -d '{}' https://api.netlify.com/build_hooks/6908472cbe9f34c6bb2b1675",
    "netlify:preview:start": "curl -X POST -H 'Content-Type: application/json' -d '{}' https://api.netlify.com/preview_server_hooks/68c5147a6f867751dd5ab91c",
    "smoke:postdeploy": "node ./scripts/post-deploy-smoke.mjs",
    "dev:clean": "./scripts/normalize-npm-env.sh npm run dev",
    "build:clean": "./scripts/normalize-npm-env.sh npm run build",
    "test:e2e:media": "node ./scripts/e2e-media-persistence.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "vite": "^7.3.1",
    "playwright": "^1.55.0"
  }
}
