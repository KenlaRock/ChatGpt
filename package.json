{
  "name": "northstar-release-deck",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit:prod": "npm audit --omit=dev",
    "netlify:build:primary": "test -n \"$NETLIFY_BUILD_HOOK_PRIMARY\" && curl -X POST -d '{}' \"$NETLIFY_BUILD_HOOK_PRIMARY\"",
    "netlify:build:secondary": "test -n \"$NETLIFY_BUILD_HOOK_SECONDARY\" && curl -X POST -d '{}' \"$NETLIFY_BUILD_HOOK_SECONDARY\"",
    "netlify:preview:start": "test -n \"$NETLIFY_PREVIEW_SERVER_HOOK\" && curl -X POST -d '{}' \"$NETLIFY_PREVIEW_SERVER_HOOK\""
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0"
  }
}
