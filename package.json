{
  "name": "northstar-release-deck",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit:prod": "npm audit --omit=dev",
    "netlify:build:primary": "node ./scripts/netlify-hook-trigger.mjs primary",
    "netlify:build:secondary": "node ./scripts/netlify-hook-trigger.mjs secondary",
    "netlify:preview:start": "node ./scripts/netlify-hook-trigger.mjs preview",
    "smoke:postdeploy": "node ./scripts/post-deploy-smoke.mjs",
    "dev:clean": "./scripts/normalize-npm-env.sh npm run dev",
    "build:clean": "./scripts/normalize-npm-env.sh npm run build",
    "test:e2e:media": "node ./scripts/e2e-media-persistence.mjs",
    "netlify:preview:start:secondary": "node ./scripts/netlify-hook-trigger.mjs preview:secondary"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "vite": "^7.3.1",
    "playwright": "^1.55.0"
  }
}
